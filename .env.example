# Copy to .env (gitignored) and fill in real values — ask Caellum for keys.
# With a .env present, start the server with just: venv/bin/python server/main.py
# Everything is optional: with nothing set, the deterministic theory layer
# plays every device and the heuristic ranker decides — no model needed.

# Decision model (gesture -> intent), OpenAI-compatible serving
WM_MODEL_URL=
WM_MODEL_NAME=
WM_MODEL_KEY=

# Bar-line composer (the live music-writing model)
WM_BARMODEL_URL=
WM_BARMODEL_NAME=
WM_BARMODEL_KEY=
# Styles the deployed model is trusted with (others play deterministically)
WM_BARMODEL_STYLES=harmonize,dense,calm,counter,echo,free,passing,arpeggio
# Bars of lookahead for composed lines: 2 for slow serving, 1 for fast hosts
# WM_BARMODEL_PREFETCH=2

# Optional extras
# WM_DEFAULT_SONG=zelda-fairy.mid     # what a fresh boot plays
# WM_PICKUP=1                          # instant sting/flourish on gestures
# WM_BACKBOARD_KEY=                    # announcer
# WM_ANNOUNCER_VOICE=                  # ElevenLabs voice id

# Gemini musical cleanup for YouTube-transcribed songs (optional)
# WM_GEMINI_KEY=
